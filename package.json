{
  "name": "mailregime",
  "version": "0.3.3",
  "description": "Country code → email-marketing-consent rules. Informational only, not legal advice.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapters/vercel": {
      "types": "./dist/adapters/vercel.d.ts",
      "import": "./dist/adapters/vercel.js",
      "default": "./dist/adapters/vercel.js"
    },
    "./adapters/cloudflare": {
      "types": "./dist/adapters/cloudflare.d.ts",
      "import": "./dist/adapters/cloudflare.js",
      "default": "./dist/adapters/cloudflare.js"
    },
    "./adapters/header": {
      "types": "./dist/adapters/header.d.ts",
      "import": "./dist/adapters/header.js",
      "default": "./dist/adapters/header.js"
    },
    "./adapters/static": {
      "types": "./dist/adapters/static.d.ts",
      "import": "./dist/adapters/static.js",
      "default": "./dist/adapters/static.js"
    },
    "./enrichers/*": {
      "types": "./dist/enrichers/*.d.ts",
      "import": "./dist/enrichers/*.js",
      "default": "./dist/enrichers/*.js"
    },
    "./store": {
      "types": "./dist/store/index.d.ts",
      "import": "./dist/store/index.js",
      "default": "./dist/store/index.js"
    },
    "./store/postgres": {
      "types": "./dist/store/postgres.d.ts",
      "import": "./dist/store/postgres.js",
      "default": "./dist/store/postgres.js"
    },
    "./schemas/*": "./schemas/*",
    "./audit": {
      "types": "./dist/audit/index.d.ts",
      "import": "./dist/audit/index.js",
      "default": "./dist/audit/index.js"
    },
    "./data/countries/*": {
      "types": "./dist/data/countries/*.d.ts",
      "import": "./dist/data/countries/*.js",
      "default": "./dist/data/countries/*.js"
    }
  },
  "files": [
    "dist",
    "schemas",
    "README.md",
    "LICENSE",
    "DISCLAIMER.md",
    "CONTRIBUTING.md",
    "COLLABORATION.md",
    "SECURITY.md",
    "AGENTS.md",
    "CHANGELOG.md",
    "llms.txt"
  ],
  "bin": {
    "mailregime": "./dist/bin/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "node --test --import tsx tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "tsc 2>/dev/null || true",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "consent",
    "gdpr",
    "can-spam",
    "casl",
    "lgpd",
    "dpdp",
    "email",
    "marketing",
    "compliance",
    "double-opt-in",
    "iso-27560"
  ],
  "author": "David Moser",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidmoserai/mailregime.git"
  },
  "bugs": {
    "url": "https://github.com/davidmoserai/mailregime/issues"
  },
  "homepage": "https://github.com/davidmoserai/mailregime#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0"
  },
  "peerDependencies": {
    "postgres": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "postgres": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "postgres": "^3.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
